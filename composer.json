{
    "name": "matteo/resilient-order-processor",
    "description": "A resilient order processing system - Backend Engineering learning project",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "slim/slim": "^4.0",
        "slim/psr7": "^1.0",
        "php-amqplib/php-amqplib": "^3.0",
        "monolog/monolog": "^3.10"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
        "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": "php -S 0.0.0.0:8080 -t public"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    }
}
